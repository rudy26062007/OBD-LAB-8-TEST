// POST - додати працівника
app.post('/employee_amenity_assignment', (req, res) => { 
    const { amenity_id, employee_id, amenity_name ,first_name, last_name } = req.body; 
    db.query('INSERT INTO employee_amenity_assignment (amenity_id, employee_id, amenity_name ,first_name, last_name) VALUES (?, ?, ?, ?, ?)', 
    [amenity_id, employee_id, amenity_name ,first_name, last_name], (err, results) => { 
    if (err) throw err; 
    res.json({ message: 'employee_assignment added', id: results.insertId }); 
    }); 
});
// PUT/PATCH - 
app.put('/employee_amenity_assignment/:employee_id', (req, res) => {
    const { amenity_id, amenity_name, first_name, last_name } = req.body;
    const { employee_id } = req.params;

    db.query(
        'UPDATE employee_amenity_assignment SET amenity_id=?, amenity_name=?, first_name=?, last_name=? WHERE employee_id=?',
        [amenity_id, amenity_name, first_name, last_name, employee_id],
        (err) => {
            if (err) throw err;
            res.json({ message: 'employee list updated' });
        }
    );
});
